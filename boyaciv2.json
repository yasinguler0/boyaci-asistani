        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  s.malzeme,\n  s.birim,\n  s.miktar AS depoda,\n  COALESCE(r.ayrilmis, 0) AS ayrilmis,\n  s.miktar - COALESCE(r.ayrilmis, 0) AS serbest\nFROM stok s\nLEFT JOIN (\n  SELECT h.malzeme, SUM(h.miktar) AS ayrilmis\n  FROM stok_hareketleri h\n  JOIN isler i ON i.id = h.is_id\n  WHERE h.yon = 'rezerv' AND i.statu = 'onaylandi'\n  GROUP BY h.malzeme\n) r ON r.malzeme = s.malzeme\nWHERE s.malzeme IN (\n  SELECT malzeme FROM stok_hareketleri WHERE is_id = $1 AND yon = 'rezerv'\n);",
        "options": {
          "queryReplacement": "={{ $json.is_id }}"
        }
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
