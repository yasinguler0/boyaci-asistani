    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT kalem, deger FROM fiyat_tarifesi;\n",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        800,
        -528
      ],
      "id": "44f78371-c905-4cf7-bef5-f98141c5c80e",
      "name": "Is tarife",
      "credentials": {
        "postgres": {
          "id": "BE0dOmnOY7gUVESa",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Tarifeyi sözlüğe çevir\nconst t = {};\nfor (const item of $input.all()) {\n  t[item.json.kalem] = Number(item.json.deger);\n}\n\n// Gemini'nin çıkardıkları\nconst p = $('Basic LLM Chain').first().json.output;\n// GUVENLIK KONTROLU: Gemini gecmis tarih verdiyse duzelt.\n// Boyaci gecmise is alamaz. Prompt'a yazdik ama garanti degil.\nif (p.is_tarihi) {\n  const bugun = new Date().toISOString().slice(0, 10);\n  if (p.is_tarihi < bugun) {\n    const parcalar = p.is_tarihi.split('-');\n    parcalar[0] = String(Number(parcalar[0]) + 1);  // yili 1 artir\n    p.is_tarihi = parcalar.join('-');\n  }\n}\nconst chatId = $('Telegram Trigger').first().json.message.chat.id;\n\n// Duvar alanı\nconst duvarAlani = p.metrekare * t.duvar_alan_carpani;\n\n// Kaç litre iç cephe boyası: duvar alani x kat / kapsama\nconst boyaLitre = Math.ceil(duvarAlani * t.kat_sayisi / t.boya_kapsama);\n\n// Tavan dahilse tavan boyası da lazım (tavan alani = zemin alani)\nconst tavanLitre = p.tavan_dahil\n  ? Math.ceil(p.metrekare * t.kat_sayisi / t.boya_kapsama)\n  : 0;\n\nreturn [{\n  json: {\n    chatId: chatId,\n    musteri_adi: p.musteri_adi,\n    is_tarihi: p.is_tarihi,\n    metrekare: p.metrekare,\n    tavan_dahil: p.tavan_dahil,\n    tutar: p.tutar,\n    duvarAlani: Math.round(duvarAlani),\n    boyaLitre: boyaLitre,\n    tavanLitre: tavanLitre\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        992,
        -528
      ],
      "id": "9f8787c1-fc1a-48dc-a1f1-0c6ec99cae6c",
      "name": "Is Hesap"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH yeni_is AS (\n  INSERT INTO isler (musteri_adi, is_tarihi, metrekare, tavan_dahil, tutar, statu)\n  VALUES ($1, $2::date, $3, $4, $5, 'onaylandi')\n  RETURNING id\n)\nINSERT INTO stok_hareketleri (is_id, malzeme, miktar, yon)\nSELECT y.id, r.malzeme, r.miktar, 'rezerv'\nFROM yeni_is y\nCROSS JOIN (VALUES\n  ('ic_cephe_boyasi', $6::numeric),\n  ('tavan_boyasi',    $7::numeric)\n) AS r(malzeme, miktar)\nWHERE r.miktar > 0\nRETURNING is_id;",
        "options": {
          "queryReplacement": "={{ $json.musteri_adi }}, {{ $json.is_tarihi }}, {{ $json.metrekare }}, {{ $json.tavan_dahil }}, {{ $json.tutar }}, {{ $json.boyaLitre }}, {{ $json.tavanLitre }}"
        }
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1200,
