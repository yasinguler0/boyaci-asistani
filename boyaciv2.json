    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  s.malzeme,\n  s.birim,\n  s.miktar AS depoda,\n  COALESCE(r.ayrilmis, 0) AS ayrilmis,\n  s.miktar - COALESCE(r.ayrilmis, 0) AS serbest,\n  s.kritik_seviye,\n  r.ilk_tarih\nFROM stok s\nLEFT JOIN (\n  SELECT h.malzeme,\n         SUM(h.miktar) AS ayrilmis,\n         TO_CHAR(MIN(i.is_tarihi), 'DD.MM.YYYY') AS ilk_tarih\n  FROM stok_hareketleri h\n  JOIN isler i ON i.id = h.is_id\n  WHERE h.yon = 'rezerv' AND i.statu = 'onaylandi'\n  GROUP BY h.malzeme\n) r ON r.malzeme = s.malzeme\nORDER BY s.malzeme;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        800,
        -672
      ],
      "id": "fcbcaa11-fccf-46bb-94d7-afb87f431929",
      "name": "Execute a SQL query1",
      "credentials": {
        "postgres": {
          "id": "BE0dOmnOY7gUVESa",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const chatId = $('Telegram Trigger').first().json.message.chat.id;\nconst satirlar = [];\n\nfor (const item of $input.all()) {\n  const s = item.json;\n  const depoda   = Number(s.depoda);\n  const ayrilmis = Number(s.ayrilmis);\n  const serbest  = Number(s.serbest);\n  const kritik   = Number(s.kritik_seviye);\n\n  // ic_cephe_boya_beyaz --> ic cephe boya beyaz\n  const ad = s.malzeme.replace(/_/g, ' ');\n\n  let satir = `${ad}: ${depoda} ${s.birim}`;\n\n  if (ayrilmis > 0) {\n    satir += ` (${ayrilmis} ayrilmis, serbest ${serbest})`;\n  }\n\n  if (serbest < 0) {\n    satir += `\\n   EKSIK ${Math.abs(serbest)} ${s.birim}`;\n    if (s.ilk_tarih) satir += ` — ${s.ilk_tarih} isine kadar al`;\n  } else if (serbest <= kritik) {\n    satir += `\\n   AZ KALDI`;\n  }\n\n  satirlar.push(satir);\n}\n\nreturn [{\n  json: {\n    chatId: chatId,\n    mesaj: 'DEPO DURUMU\\n\\n' + satirlar.join('\\n')\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
