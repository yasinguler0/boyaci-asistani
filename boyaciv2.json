        "jsCode": "// Gemini'nin ham cevabini al\nlet ham = $json.content?.parts?.[0]?.text\n       ?? $json.text\n       ?? $json.content\n       ?? '';\n\n// ```json ve ``` isaretlerini temizle\nham = ham.replace(/```json/g, '').replace(/```/g, '').trim();\n\n// Metni gercek JSON'a cevir\nlet kalemler;\ntry {\n  kalemler = JSON.parse(ham);\n} catch (e) {\n  kalemler = [];\n}\n\nconst chatId = $('Telegram Trigger').first().json.message.chat.id;\n\n// Hic kalem yoksa\nif (!Array.isArray(kalemler) || kalemler.length === 0) {\n  return [{\n    json: {\n      chatId: chatId,\n      bos: true,\n      kalemler: []\n    }\n  }];\n}\n\n// Her kalemi ayri satir yap (depoya tek tek eklemek icin)\nreturn kalemler.map(k => ({\n  json: {\n    chatId: chatId,\n    malzeme: k.malzeme,\n    miktar: Number(k.miktar),\n    bos: false\n  }\n}));"
