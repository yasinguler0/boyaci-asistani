        "jsCode": "const chatId = $('Fis Parse').first().json.chatId;\n\n// Fis bos muydu? (hic taninan kalem yoksa)\nconst parseSonuc = $('Fis Parse').all();\nif (parseSonuc.length === 1 && parseSonuc[0].json.bos === true) {\n  return [{ json: {\n    chatId: chatId,\n    mesaj: 'Fiste depoya uygun malzeme bulunamadi.'\n  }}];\n}\n\n// Eklenen her malzemenin guncel halini topla\nlet mesaj = 'FISTEN EKLENDI\\n\\n';\nfor (const item of $input.all()) {\n  const s = item.json;\n  const ad = s.malzeme.replace(/_/g, ' ');\n  mesaj += `${ad}: artik ${Number(s.miktar)} birim depoda\\n`;\n}\n\nreturn [{ json: { chatId: chatId, mesaj: mesaj } }];"
