    {
      "parameters": {
        "jsCode": "const h = $('Is Hesap').first().json;\n\n// 2027-04-15 --> 15.04.2027\nconst [y, m, g] = h.is_tarihi.split('-');\nconst tarih = `${g}.${m}.${y}`;\n\nlet mesaj = 'IS KAYDEDILDI\\n\\n';\nmesaj += `Musteri: ${h.musteri_adi}\\n`;\nmesaj += `Tarih: ${tarih}\\n`;\nmesaj += `Ev: ${h.metrekare} m2 (tavan ${h.tavan_dahil ? 'dahil' : 'haric'})\\n`;\nmesaj += `Tutar: ${h.tutar} TL\\n\\n`;\nmesaj += 'AYRILAN MALZEME\\n';\n\nconst eksikler = [];\n\nfor (const item of $input.all()) {\n  const s = item.json;\n  const ad = s.malzeme.replace(/_/g, ' ');\n  const serbest = Number(s.serbest);\n\n  mesaj += `${ad}: depoda ${Number(s.depoda)} ${s.birim}, toplam ayrilmis ${Number(s.ayrilmis)}\\n`;\n\n  if (serbest < 0) {\n    eksikler.push(`${ad}: ${Math.abs(serbest)} ${s.birim}`);\n  }\n}\n\nif (eksikler.length > 0) {\n  mesaj += `\\nALINACAK (${tarih} isine kadar)\\n`;\n  for (const e of eksikler) {\n    mesaj += `- ${e}\\n`;\n  }\n} else {\n  mesaj += '\\nStok yeterli, alacak bir sey yok.\\n';\n}\n\nreturn [{ json: { chatId: h.chatId, mesaj: mesaj } }];"
      },
