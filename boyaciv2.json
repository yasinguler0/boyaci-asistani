    {
      "parameters": {
        "jsCode": "// Fiyat listesini kolay okunur hale getir\nconst t = {};\nfor (const item of $input.all()) {\n  t[item.json.kalem] = Number(item.json.deger);\n}\n\n// Gemini'nin çıkardığı bilgileri al\nconst p = $('Basic LLM Chain').first().json.output;\n\n// Duvar alanı: boyacı \"120 m2 ev\" der ama boyanan zemin değil, duvarlar\nconst duvarAlani = p.metrekare * t.duvar_alan_carpani;\n\n// Duvar parası\nlet tutar = duvarAlani * t.duvar_m2;\n\n// Tavan istiyorsa ekle\nif (p.tavan_dahil) {\n  tutar += p.metrekare * t.tavan_m2;\n}\n\n// Çok küçük işlerde minimum tutar uygula\ntutar = Math.max(tutar, t.min_is_tutari);\n\n// 100 TL'ye yuvarla (boyacı \"27.834 TL\" demez)\ntutar = Math.round(tutar / 100) * 100;\n\n// Kaç litre boya lazım\nconst litre = Math.ceil(duvarAlani * t.kat_sayisi / t.boya_kapsama);\n\nreturn [{\n  json: {\n    chatId: $('Telegram Trigger').first().json.message.chat.id,\n    metrekare: p.metrekare,\n    oda_tipi: p.oda_tipi,\n    tavan_dahil: p.tavan_dahil,\n    duvarAlani: Math.round(duvarAlani),\n    litre: litre,\n    tutar: tutar\n  }\n}];"
      },
