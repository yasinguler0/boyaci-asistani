    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH hedef AS (\n  SELECT id FROM isler\n  WHERE musteri_adi ILIKE '%' || $1 || '%' AND statu = 'onaylandi'\n  ORDER BY id DESC\n  LIMIT 1\n),\nguncelle AS (\n  UPDATE isler SET statu = 'tamamlandi'\n  WHERE id = (SELECT id FROM hedef)\n  RETURNING id\n),\ndusum AS (\n  UPDATE stok s\n  SET miktar = s.miktar - h.miktar\n  FROM stok_hareketleri h\n  WHERE h.is_id = (SELECT id FROM hedef)\n    AND h.yon = 'rezerv'\n    AND s.malzeme = h.malzeme\n)\nSELECT id FROM guncelle;",
        "options": {
          "queryReplacement": "={{ $('Basic LLM Chain').first().json.output.musteri_adi }}"
        }
      },
